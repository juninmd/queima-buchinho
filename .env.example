# Queima Buchinho - Environment Variables

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID
CHAT_ID=your_chat_id_here

# Ollama LLM Service
OLLAMA_HOST=http://localhost:11434

# LiteLLM/OpenAI Compatible API configuration
LITELLM_API_KEY=your_litellm_api_key_here
LITELLM_BASE_URL=https://your-litellm-domain.com/v1
AI_MODEL=gemini-2.5-flash-lite

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/queima_buchinho

# Redis Cache
REDIS_URL=redis://localhost:6379

# Giphy API Key (get from https://developers.giphy.com/)
# The public beta key is BANNED - you need your own key
GIPHY_API_KEY=your_giphy_api_key_here
