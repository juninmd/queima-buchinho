# Queima Buchinho - Environment Variables

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (onde a Mika ENVIA as mensagens — grupo ou privado)
CHAT_ID=your_chat_id_here

# Seu Telegram User ID PESSOAL (dono dos hábitos/água/treino).
# Em GRUPO, CHAT_ID é o id do grupo e difere do seu id pessoal: sem USER_ID, os
# relatórios do cron leem 0/12. Em chat privado pode omitir (cai no CHAT_ID).
USER_ID=your_personal_telegram_user_id

# Ollama LLM Service
OLLAMA_HOST=http://localhost:11434

# LiteLLM/OpenAI Compatible API configuration
LITELLM_API_KEY=your_litellm_api_key_here
LITELLM_BASE_URL=https://your-litellm-domain.com/v1
AI_MODEL=cloud/llama-70b

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/queima_buchinho

# Redis Cache
REDIS_URL=redis://localhost:6379

# Giphy API Key (get from https://developers.giphy.com/)
# The public beta key is BANNED - you need your own key
GIPHY_API_KEY=your_giphy_api_key_here

# User birthday (DD/MM/YYYY) — Mika celebrates with GIF, sticker, sounds and voice at 9am
USER_BIRTHDAY=14/06/1995
